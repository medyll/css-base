{
  "name": "css-base",
  "version": "1.0.0",
  "description": "Modern CSS design system library",
  "files": [
    {
      "file": "app.css",
      "description": "Entry point — declares all layers and imports everything",
      "layers": ["base", "theme.reset", "theme.variables", "theme.tokens", "theme.typography", "theme.palette", "theme.components", "utilities", "workspace"]
    },
    {
      "file": "base.css",
      "description": "HTML resets and font defaults",
      "layer": "base"
    },
    {
      "file": "reset.css",
      "description": "HTML resets and base styles",
      "layer": "theme.reset"
    },
    {
      "file": "variables.css",
      "description": "Base spacing scale",
      "layer": "theme.variables"
    },
    {
      "file": "tokens.css",
      "description": "Semantic tokens (padding, margins, radius, motion, z-index)",
      "layer": "theme.tokens"
    },
    {
      "file": "typography.css",
      "description": "Font families, sizes, weights, line heights, letter spacing",
      "layer": "theme.typography"
    },
    {
      "file": "palette.css",
      "description": "Colors, surfaces, shadows, technical dimensions",
      "layer": "theme.palette"
    },
    {
      "file": "components.css",
      "description": "Base components (headings, inputs, buttons) and @function declarations",
      "layer": "theme.components"
    },
    {
      "file": "utilities.css",
      "description": "Utility classes for layout, spacing, typography, color, and hover variants",
      "layer": "utilities"
    },
    {
      "file": "workspace.css",
      "description": "Application shell layout and UI components (app-shell, cards, menus)",
      "layer": "workspace"
    }
  ],
  "compatibility": {
    "browsers": ["Chrome >= 125", "Edge >= 125"],
    "features": [
      "@layer",
      "CSS Nesting",
      "color-mix()",
      "light-dark()",
      "relative color syntax (hsl/oklch from)",
      "CSS Anchor Positioning",
      "text-box-trim / text-box-edge",
      "subgrid",
      "text-wrap: balance",
      "@function (CSS Values Level 5) — Chromium 139+",
      "prefers-contrast",
      "prefers-reduced-motion"
    ]
  }
}
